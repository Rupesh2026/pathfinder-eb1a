# Supabase — get these from your Supabase project Settings > API
# Public values are safe to expose to the browser; RLS is the security boundary
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side API routes only, NEVER exposed to the browser
# (used by /api/evaluate, /api/advisor, /api/knowledge, auth actions, etc.)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Agent server — URL of your Render deployment (no trailing slash).
# Set BOTH to the same eb1a-agent-server URL.
AGENT_SERVER_URL=https://your-agent-server.onrender.com
RENDER_SERVICE_URL=https://your-agent-server.onrender.com

# Shared secret between Next.js API routes and the agent server.
# Must match CRON_API_KEY in the agent server's environment.
CRON_API_KEY=your-cron-api-key-here

# AI keys — routes pick the first available (Anthropic > OpenAI > Gemini).
# Add at least one. OpenAI is also required for the evaluator + advisor (embeddings).
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Evaluator results email (Resend) — used by /api/evaluate
RESEND_API_KEY=your-resend-api-key-here
