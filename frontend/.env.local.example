# Supabase — get these from your Supabase project Settings > API
# Safe to expose to browser; RLS is the security boundary
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Agent server — URL of your Render deployment (no trailing slash)
# Used by Next.js API routes (server-side only, never exposed to browser)
AGENT_SERVER_URL=https://your-agent-server.onrender.com

# Shared secret between Next.js API routes and the agent server
# Must match CRON_API_KEY in your Render environment variables
CRON_API_KEY=your-cron-api-key-here

# AI Advisor — uses the first key it finds (Anthropic takes priority)
# Add either one (or both); Gemini works right away if you have it
GEMINI_API_KEY=your-gemini-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
