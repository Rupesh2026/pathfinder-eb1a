# Supabase — use the service role key so agents bypass RLS
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# LLM provider: "gemini" or "openai"
LLM_PROVIDER=openai

# OpenAI (used if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key

# Gemini / Vertex AI (used if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_APPLICATION_CREDENTIALS=vertex_key.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=0

# Web search — Tavily API key (used by DiscoveryAgent)
TAVILY_API_KEY=your-tavily-api-key

# Render cron security — must match CRON_API_KEY in frontend/.env.local
CRON_API_KEY=your-secret-cron-key

# Local Postgres (optional, for local development only)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
